      "parameters": {
        "jsCode": "const fastapi = $('🧠 FastAPI — Cerebro IA').first().json;\nconst telefono = $('🔧 Normalizar Payload').first().json.telefono || '5493765384843';\n\nconst respuesta = fastapi.respuesta || '';\nconst tipoMsg = String(fastapi.tipo_mensaje || 'texto');\nconst imagenUrl = String(fastapi.imagen_url || '');\n\n// Booleano explícito para el IF node\nconst esImagen = (tipoMsg === 'imagen' && imagenUrl.length > 10) ? true : false;\n\nreturn [{\n  json: {\n    telefono,\n    respuesta,\n    tipo_mensaje: tipoMsg,\n    imagen_url: imagenUrl,\n    es_imagen: esImagen\n  }\n}];"
