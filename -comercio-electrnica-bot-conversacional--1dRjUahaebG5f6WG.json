      "parameters": {
        "jsCode": "const fastapi = $('🧠 FastAPI — Cerebro IA').first().json;\nconst telefono_cliente = $('🔧 Normalizar Payload').first().json.telefono || 'desconocido';\nconst accion = fastapi.accion_ejecutada || 'lead';\nconst respuesta_bot = fastapi.respuesta || '';\n\nconst ahora = new Date().toLocaleString('es-AR', {timeZone: 'America/Argentina/Buenos_Aires'});\n\nlet texto;\nif (accion === 'lead_notificado') {\n  texto = `🔥 *LEAD CALIFICADO — Casa Electrónica*\\n\\n📱 Cliente: ${telefono_cliente}\\n💬 Bot respondió: ${respuesta_bot.substring(0, 100)}...\\n⏰ ${ahora}`;\n} else {\n  texto = `📞 *CLIENTE PIDE VENDEDOR — Casa Electrónica*\\n\\n📱 Cliente: ${telefono_cliente}\\n💬 Bot respondió: ${respuesta_bot.substring(0, 100)}...\\n⏰ ${ahora}`;\n}\n\nreturn [{ json: { texto_alerta: texto, telefono_dueno: '5493765384843' } }];"
