    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────\n// Normalizar el payload de Evolution API\n// ─────────────────────────────────────────────\nconst body = $input.first().json.body;\n\n// FILTRO 1: Solo procesar eventos messages.upsert\nconst event = body?.event || '';\nif (event !== 'messages.upsert') {\n  return [{ json: { ignorar: true } }];\n}\n\n// Extraer ID único del mensaje (para deduplicación)\nconst messageId = body?.data?.key?.id || '';\n\n// Extraer teléfono (quitar @s.whatsapp.net)\nconst remoteJid = body?.data?.key?.remoteJid || '';\nconst telefono = remoteJid.replace('@s.whatsapp.net', '').replace('@g.us', '');\n\n// Extraer texto del mensaje\nconst msgData = body?.data?.message || {};\nconst mensaje = \n  msgData?.conversation ||\n  msgData?.extendedTextMessage?.text ||\n  msgData?.imageMessage?.caption ||\n  '';\n\n// Detectar si tiene imagen\nconst messageType = body?.data?.messageType || '';\nconst tiene_imagen = ['imageMessage', 'documentMessage'].includes(messageType);\n\nconst es_admin = false;\n\n// FILTRO 2: Ignorar mensajes propios o de grupos\nconst from_me = body?.data?.key?.fromMe || false;\nif (from_me || remoteJid.includes('@g.us')) {\n  return [{ json: { ignorar: true } }];\n}\n\n// FILTRO 3: Ignorar si no es un número personal de WhatsApp\nif (!remoteJid.endsWith('@s.whatsapp.net')) {\n  return [{ json: { ignorar: true } }];\n}\n\n// FILTRO 4: Ignorar mensajes vacíos\nif (!mensaje.trim()) {\n  return [{ json: { ignorar: true } }];\n}\n\nreturn [{\n  json: {\n    telefono,\n    mensaje: mensaje.trim(),\n    tiene_imagen,\n    es_admin,\n    ignorar: false,\n    messageId\n  }\n}];"
      },
