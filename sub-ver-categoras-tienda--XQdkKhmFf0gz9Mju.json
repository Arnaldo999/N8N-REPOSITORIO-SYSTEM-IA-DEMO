      ],
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst categorias = items.map((item, i) => {\n  const f = item.json.fields || item.json;\n  return {\n    numero: i + 1,\n    nombre: f.Nombre || f.nombre || '',\n    emoji: f.Emoji || f.emoji || '📦'\n  };\n});\n\nlet texto = '🛍️ *Estas son nuestras categorías:*\\n\\n';\ncategorias.forEach(c => {\n  texto += `${c.numero}. ${c.emoji} *${c.nombre}*\\n`;\n});\ntexto += '\\nEscribí el *número* de la que te interesa 😊';\n\nreturn [{ json: { response: texto } }];"
      }
    },
